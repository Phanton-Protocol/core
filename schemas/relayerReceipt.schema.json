{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RelayerReceipt",
  "type": "object",
  "required": [
    "version",
    "intentId",
    "nullifier",
    "inputCommitment",
    "outputCommitmentSwap",
    "outputCommitmentChange",
    "inputAssetId",
    "outputAssetIdSwap",
    "outputAssetIdChange",
    "inputAmount",
    "swapAmount",
    "changeAmount",
    "protocolFee",
    "gasRefund",
    "txHash",
    "blockNumber",
    "encryptedPayload"
  ],
  "properties": {
    "version": { "type": "string" },
    "intentId": { "type": "string" },
    "nullifier": { "type": "string" },
    "inputCommitment": { "type": "string" },
    "outputCommitmentSwap": { "type": "string" },
    "outputCommitmentChange": { "type": "string" },
    "inputAssetId": { "type": "integer" },
    "outputAssetIdSwap": { "type": "integer" },
    "outputAssetIdChange": { "type": "integer" },
    "inputAmount": { "type": "string" },
    "swapAmount": { "type": "string" },
    "changeAmount": { "type": "string" },
    "outputAmountSwap": { "type": "string" },
    "protocolFee": { "type": "string" },
    "gasRefund": { "type": "string" },
    "txHash": { "type": "string" },
    "blockNumber": { "type": "integer" },
    "encryptedPayload": { "type": "string" },
    "relayer": { "type": "string" },
    "timestamp": { "type": "integer" }
  }
}
