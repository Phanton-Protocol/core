# tfhe-matching-service — environment template.
#
# Copy to .env (NEVER commit .env).
# For production keys: use a KMS / TEE; for dev / testnet v1, filesystem with
# restricted permissions is acceptable per the v1 ops runbook.

# Express listen port.
MATCHING_SERVICE_PORT=4001

# Bind address. Use 127.0.0.1 in dev; the relayer talks to this service over
# loopback. Production: only expose behind mTLS / VPC.
MATCHING_SERVICE_BIND=127.0.0.1

# 32-byte hex private key for the attestation signer (secp256k1). The recovered
# address from a signed decisionHash MUST be advertised to the relayer as
# EXPECTED_FHE_ATTESTATION_SIGNER.
#
# **Default 0x11..11 is dev-only — never use in production.**
MATCHING_SERVICE_PRIVATE_KEY=0x1111111111111111111111111111111111111111111111111111111111111111

# TFHE key material. Both files are auto-generated on first boot if missing.
# These paths are gitignored. Restrict filesystem permissions to the service user.
TFHE_PUBLIC_KEY_PATH=./keys/public.key
TFHE_SECRET_KEY_PATH=./keys/secret.key

# Optional. If set, the service refuses to boot when the loaded keys' fingerprint
# disagrees with this value. Use this to pin the deployed key set across restarts.
# Leave blank to accept whatever is on disk.
TFHE_KEY_FINGERPRINT=
