{
  "name": "phantom_join_split_routing_commitment_v1",
  "description": "Canonical routing commitment derived in-circuit from private join-split routing metadata for relayer hash-first authorization.",
  "fields_order": [
    "inputAssetID",
    "outputAssetIDSwap",
    "outputAssetIDChange",
    "inputAmount",
    "swapAmount",
    "changeAmount",
    "outputAmountSwap",
    "minOutputAmountSwap",
    "protocolFee",
    "gasRefund",
    "withdrawMode"
  ],
  "encoding": "MiMC7 chain: r0=mimc7(inputAssetID,outputAssetIDSwap) ... r9=mimc7(r8,withdrawMode)",
  "hash": "MiMC7",
  "consumers": [
    "backend/src/zkProofs.js",
    "backend/src/index.js",
    "contracts/_full/core/ShieldedPool.sol"
  ]
}
